@model Inventory_App.Models.Product

@{
    ViewData["Title"] = "Create";
}
<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white rounded-top-4">
            <h4 class="mb-0">➕ Create New Product</h4>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Product Name -->
                <div class="mb-3">
                    <label asp-for="ProductName" class="form-label fw-semibold"></label>
                    <input asp-for="ProductName" class="form-control form-control-lg" placeholder="Enter product name..." />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <!-- Supplier & Category -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SupplierId" class="form-label fw-semibold">Supplier</label>
                        <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.SupplierItem">
                            <option value="-1">-- Select Supplier --</option>
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryItem">
                            <option value="-1">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                </div>

                <!-- Quantity -->
                <div class="mb-3">
                    <label asp-for="QuantityPerUnit" class="form-label fw-semibold"></label>
                    <input asp-for="QuantityPerUnit" class="form-control" placeholder="e.g. 10 boxes x 20 bags" />
                    <span asp-validation-for="QuantityPerUnit" class="text-danger"></span>
                </div>

                <!-- Discontinued -->
                <div class="form-check form-switch mb-4">
                    <input class="form-check-input" asp-for="Discontinued" />
                    <label class="form-check-label fw-semibold" asp-for="Discontinued"></label>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        ⬅ Back
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                        ✔ Create
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
